      <body>
         <div type="edition" xml:lang="kan-Latn">
             
             <lg n="1" met="anuṣṭubh" xml:lang="san-Latn">
                 <l n="a"><lb n="1"/><supplied reason="lost" evidence="parallel">śubham</supplied> bhūyājjinendrāṇā <supplied reason="lost" evidence="parallel">ṁ</supplied></l>
                 <l n="b">śāsanāghanāśinē </l>
                 <l n="c">ku<supplied reason="lost" evidence="parallel">tīrttha</supplied> dhvānta-saṁghāta</l>
                 <l n="d">prabhinna <supplied reason="lost" evidence="parallel">ghanabhānavē</supplied> <supplied reason="lost"><g type="punctuation" ref="sym:doubleBar">.</g></supplied></l>
             </lg>
             
             <lg n="2" met="śārdūlavikrīḍita" xml:lang="san-Latn">
                <l n="a">śrīmad-rāma-ma <supplied reason="lost">hīṁ</supplied>/supplied&gt; <lb n="2" break="no"/> dra-datta-sakaḷa-kṣōṇī-vadhū-maṇḍanē</l> 
                <l n="b">sākṣāt-kōkanadāsanēna sadṛśaṁ brahmātmajaissēvitē</l> 
                <l n="c">śumbhattōyaja-nābha-sattananibhī <lb n="3" break="no"/> śrīlokkiguṇḍyāh vayē</l>
                <l n="d">jainasthānam acīkarad guṇa-nidhiḥ śrī-dāna-cintāmaṇiḥ <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
             <lg n="3" met="unknown" xml:lang="san-Latn">
                 <l n="a">cāḷukya-cakri-dhvajinīpamātra</l>
                 <l n="b">samarppitaḥ kā <lb n="4" break="no"/> rita-jainagēhaḥ<gap reason="illegible" unit="character" quantity="1"/></l>
                 <l n="c">śrī-lokkiguṇḍyā<supplied reason="omitted">ḥ</supplied> paripāḷanārthaṁ</l> 
                 <l n="d">sahasrasaṁ khyeṣu dharāmarēṣu <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
            <p>
                <lb n="5"/><g type="symbol" ref="sym:spiral-spoked"/>svasti samasta-bhuvanāśraya-śri-pṛthvīvallabha-mahārājādhirāja-paramēśvara-paramabhaṭṭāraka-satyāśraya-kuḷatilaka-cāḷukyābha
                <lb n="6" break="no"/>raṇa-śrīmad-āhavamalla-dēvara rājyam uttarōttarābhivṛddhi pravarddamānam ā candrārka-tārambaram saluttamire tat-pāda-padmōpajīviyu
                <lb n="7" break="no"/>m akhila rājyabhara ṇirūpita mahā-mantrākṣapaṭaḷādhipatiyum enisi <g type="punctuation" ref="sym:doubleBar">.</g></p> 
             
             <ab>kanda <g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <lg n="4" met="kanda">
                <l n="a">mallāmalliyoḷ āntari</l>
                <l n="b" enjamb="yes">mallaran āhavadoḷ ottigō<lb n="8" break="no"/>ḷ marigoḷv’ ī</l>
                <l n="c">ballāḷtanadind’ āhava</l>
                <l n="d" enjamb="yes">mallana bhujadaṇḍam enisi <choice><sic>dhaṁllaṁ</sic><corr>dhallaṁ</corr></choice> negaḻdam <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>            
            
            <ab>vr̥tta<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <lg n="5">
                 <l n="a">poṇardd’ idir āgi tāgi doranāneyoḷ okkuvan andu bercce koṁ</l>
                 <l n="b" enjamb="yes">kaṇam eḻdiyikke beṁgi beṟagāge tivuḷḷelanḷke māḷava</l>
                 <l n="c" enjamb="yes">maṇiyi podaḷdudirkkelade munddaṇa-sindaṇa-maṇḍalakke bhī</l>
                 <l n="d" enjamb="yes">ṣaṇam atiraudrama <lb n="10" break="no"/>dbhutam agurvvine tējadaḷ urkke dhallana<g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
             <ab>kanda <g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <lg n="6" met="kanda">
                 <l n="a">dhallana negaḻdāhava</l>
                 <l n="b" enjamb="yes">mallaṁgaṁ bhēdamuṇṭe vibhavadoḷ adanēn</l>
                 <l n="c" enjamb="yes">ellarum aRiyar dharaṇī</l>
                 <l n="d" enjamb="yes">valla <lb n="11" break="no"/> bha siṁhāsanaika-bhēdame bhēda<supplied reason="omitted">ṁ</supplied><g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
             <ab>va<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <p> antu maṇḍaḷa-siddhiyum vivēka-br̥haspatiyum enisi negaḻda dhallana piriya magaṁ</p>
             
             
             <ab>vr̥<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <lg n="7" met="mattebhavikrīḍita">
                 <l n="a"> bharadiṁ <lb n="12"/>rāvaṇa-sēseyaṁ tavisi geld' ā gaṇḍaruṁ bhaṇḍaṇā</l>
                 <l n="b" enjamb="yes">jiradoḷ kauravasēseyam tuḷidu geld' ā gaṇḍaruṁ gaṇḍama</l>
                 <l n="c" enjamb="yes">ccaradiṁ śaktiya bīraraṁ <lb n="13" break="no"/> ponaḻdu geld' ā gaṇḍaruṁ vīta-mat</l>
                 <l n="d" enjamb="yes">saradiṁ bhāvisuv' āgaḷē semarakoḷ gaṇḍaṁ baraṁ gaṇḍarē <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
             <ab>va<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <p>ā vājikuḷatiḷakajuṁ tējōbhāskaranuṁ
             <lb n="14"/>vīra-triṇētranuṁ nanni-mahārṇnavanuṁ kanduka-purandaranum enisuva vīrāgraṇiya parākramamē dorentene</p>
             
             <ab>vr̥<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <lg n="8" met="unknown">
                 <l n="a">dhāḷiyo<lb n="15" break="no"/>ḷ andhranaṁ piḍidapeṁ magadhēśanan ikki meṭṭipeṁ</l>
                 <l n="b">lāḷana gaṇṭalaṁ muridapeṁ khasanaṁ puḍiyoḷ poraḷcapeṁ</l>
                 <l n="c">kōḷadoḷ ikkipeṁ maleva pā<lb n="16" break="no"/>ṇḍyanan āhavamalladēvaniṁ</l>
                 <l n="d">pēḷ enutirppan ī doretu  śauryaguṇōnnati nāgadēvana <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
             <ab>va<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <p>ā mahīdēva-kuḷa-gagana-gabha
             <lb n="17" break="no"/>sti-māḷige mahā-satī-ratnaṁ kuḷa-patniyāgi guṇadaṁkakārtiyuṁ kavivara-kāmadhēnumuṁ kaṭakapavitreyuṁ ji
             <lb n="18" break="no"/>na-dharma-patākeyum enisida dānacintāmaṇiya mahāprabhāvamē dōrentene <g type="punctuation" ref="sym:doubleBar">.</g></p>
             
             <ab>vr̥<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
             <lg n="9" met="utpalamala">
                 <l n="a">unnata kukkuṭēśvara jinēśvaranaṁ <lb n="19"/> jinabhakti pōgi kāṇ</l>
                 <l n="b" enjamb="yes">bannegam annamaṁ toṟedu parvvatamaṁ mudadēṟe tajjinā</l>                 
                 <l n="c" enjamb="yes">sannadoḷ attiyabbege pathaśramam ādōḍ’ akāḷavṛṣṭi<lb n="20"/>yāy</l> 
                 <l n="d" enjamb="yes">t’ innavu dēva-bhaktig’ adu cōdyame koḷḷave puḻvavṛṣṭigaḷ <g type="punctuation" ref="sym:doubleBar">.</g></l></lg>
             
             <lg n="10" met="kanda">
                 <l n="a">narapana besadiṁ jinanaṁ</l>
                 <l n="b">śiradoḷ sale tāḷdi dānacintāmaṇi nir</l>
                 <l n="c" enjamb="yes">bbha<lb n="21"/>ra gōdāvariyaṁ puge</l>
                 <l n="d">pariyuḍugidud’ eṁdoḍ’ oḷvan’ adenē vēḷveṁ <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>
             
             <lg n="11" met="kanda">
                 <l n="a">madavat kari seṟeyaṁ paḻi</l>
                 <l n="b" enjamb="yes">d' odavida muḷisinde bhōreney taṁdoḍ' adar</l>
                 <l n="c" enjamb="yes">kk' ad' i<lb n="22" break="no"/>radire bhaktiyiṁd' adu</l>
                 <l n="d" enjamb="yes">padayuga keḻag' idudu dānacintāmaṇiya <g type="punctuation" ref="sym:doubleBar">.</g></l>
             </lg>

           <lg n="12" met="kanda">
               <l n="a">mudad' arcccipa jina-bimbaṁ</l>
               <l n="b">nadiyoḷ key bardduki biṟdoḍ' adu bappinam u<lb n="23" break="no"/>ṇ</l>
               <l n="c" enjamb="yes">b' adan uḷid' iral enṭudinakk</l>
               <l n="d" enjamb="yes">adu bandudu kayge dānacintāmaṇiya <g type="punctuation" ref="sym:doubleBar">.</g></l>
           </lg>
             
           <lg n="13" met="kanda">
               <l n="a">praḷeyāgniyante kaṭakama</l>
               <l n="b" enjamb="yes">n oḷakoṇḍaḷ urvvagni dānacintāma<lb n="23" break="no"/>ṇi nir</l>
               <l n="c" enjamb="yes">mmaḷa-jana-gandhōdakamaṁ</l>
               <l n="d">taḷiyal kupaśamisitendoḍe vaṇṇisuve <g type="punctuation" ref="sym:doubleBar">.</g></l>
           </lg>
             
          <lg n="14" met="kanda">
              <l n="a">oḍanēṟe savati noṁkal</l>
              <l n="b">koḍarise toṟeyoḷage paḻugala<lb n="25"/>ttittalaṇaṁ</l>
              <l n="c">miḍukade tiriyuttire kaṇ</l>
              <l n="d" enjamb="yes">ḍaḍigeṟagidaḷ attiyabbe-satibhayavaśadiṁ <g type="punctuation" ref="sym:doubleBar">.</g></l>
          </lg>
             
         <lg n="15" met="kanda">
             <l n="a">jina-dharma-patākege vima</l>
             <l n="b" enjamb="yes">ḷa narmadānadiya <lb n="26"/><supplied reason="lost"><choice><unclear>ku</unclear><unclear>ka</unclear></choice></supplied>ruḷapāveya jinanaṁ</l>
             <l n="c">vinutaṁ kāṇb' inegaṁ kū</l>
             <l n="d" enjamb="yes">ḷane toṟedudu sandud' antad' ā janmāntaṁ <g type="punctuation" ref="sym:doubleBar">.</g></l>
         </lg>
             
        <ab>vr̥<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
        <lg n="16" met="campakamālā">
            <l n="a">jina-pada-paṁkaja-bhramaran emba negartteya<lb n="27" break="no"/>n āḷda mallapa</l>
            <l n="b" enjamb="yes">yyana negaḻd’ appakabbeya magaḷ śacivōttaman appa dhallapa</l>
            <l n="c" enjamb="yes">yyana sose nāgadēvana kuḷāṁgane tailana tāyjasakke bhā</l>
            <l n="d" enjamb="yes">janam e<lb n="28" break="no"/>nim attimabbe jina-śāsanamaṁ beḷaguttam iḻdapaḷ <g type="punctuation" ref="sym:doubleBar">.</g></l>
        </lg>
             
        <lg n="17" met="campakamālā">
           <l n="a">eṇe marudēvi pāsaṭi suṣēṇi samaṁ śivadēvi pāṭi lak</l>
           <l n="b" enjamb="yes">ṣaṇe sadṛśam mahāvijaya<lb n="29" break="no"/>sēne samāne susīḷe pōlva rug</l>
           <l n="c" enjamb="yes">miṇi sari satyabhāme toṇe mikka suḷocane tatsvarūpe rō</l>
           <l n="d" enjamb="yes">hiṇi dore saṁd’ arundhati peṟaṟ do<lb n="30" break="no"/>reye guṇad’ ankakārtiyoḷ</l>
        </lg>
             
        <lg n="18" met="mattebhavikrīḍita">
            <l n="a">parama śrī-jinanātha-gēha-viḷasac-chaṁdōha-saṁdōha-bhā</l>
            <l n="b" enjamb="yes">sura-jaina-pratimā-vicitra-maṇi-ghaṁṭā<lb n="31" break="no"/>māḷikā-saṁkhe sā</l>
            <l n="c" enjamb="yes">yirad-aynūṟ' ivu bēḻaveṟinipinaṁ nirmmāpaṇaṁ geydu bhū</l>
            <l n="d" enjamb="yes">bharadoḷ dharman atimabbeyavol int’ ār ujvaḷaṁ<lb n="32" break="no"/> māḍidar <g type="punctuation" ref="sym:doubleBar">.</g></l>
        </lg>
             
        <ab>kaṁ<g type="punctuation" ref="sym:doubleBar">.</g></ab>
        
        <lg n="19" met="kanda">
            <l n="a">ā paramēśvarige jagad</l>
            <l n="b" enjamb="yes">vyāpakaśuddhēndukīrtti piriyamagaṁ lakṣ</l>
            <l n="c" enjamb="yes">mīpati samagravijaya</l>
            <l n="d" enjamb="yes">śrīpatiyene dharege nega<lb n="33" break="no"/>ḻda paḍavaḷa tailaṁ <g type="punctuation" ref="sym:doubleBar">.</g></l>
        </lg>
             
        <lg n="20" met="campakamālā">
            <l n="a">pagaraṇam aṇma meccupa nighṛṣṭiye būdiyi<supplied reason="omitted">ṁ</supplied> boṭṭu gaṇḍav’ ā</l>
            <l n="b" enjamb="yes">tugi bagi kīrti kuppa kuṟi muttara modale peṁ<lb n="34" break="no"/>pu vikramaṁ</l>
            <l n="c">bhagavatiyēṟu śaucaguṇam attiya paṇnanipēḷapuṇḍaraṁ</l>
            <l n="d">tegaḷvudud’ āra-cāru-carita-prabheyiṁ paḍevaḷḷa tailana <g type="punctuation" ref="sym:doubleBar">.</g></l>
        </lg>
             
        <ab>va<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
        <p>
        <lb n="35"/>Intu nanni-nārāyaṇaṁ samyaktva-ratnākaraṁ patimecce-gaṇḍan āḷdana-cakraṁ karppvūra-varṣam catura-caturānanaṁ guṇa-mēru vāyidhā
        <lb n="36" break="no"/>cāryan eṁba nāma-māḷe dig-vadhū-dhamm' ellam āḷe yenisi śrīmat-vaḍevaḷḷa tailapayyaṁ māsavāḍi nuṟanālvattumaṁ bēḷavṛ
        <lb n="37" break="no"/>ttiyin āḷuttamire <g type="punctuation" ref="sym:doubleBar">.</g></p>
             
        <ab>vr̥<g type="punctuation" ref="sym:doubleBar">.</g></ab>
             
        <lg n="20" met="mahāsragdharā">
           <l n="a">viḷasad-bhūdēva-vēda-dhvani-samucita-dharmmārttha-śāstrārtthava-nnir</l>
           <l n="b" enjamb="yes">maḷa-dharmmārtthōkti nānā-janapada ja<supplied reason="lost">na</supplied>
               <lb n="38" break="no"/>tānanda-kōḷāha<seg met="-+"><gap reason="lost" unit="character" quantity="2"/></seg></l>
           <l n="c"><seg met="--++"><gap reason="lost" unit="character" quantity="4"/></seg>ṇya-sampad-viḷasana-maḷavaṭṭirppinaṃ tannoḷ urvvī</l>
           <l n="d" enjamb="yes">lalanā-lālāṭa-līḷā=tiḷakam enisi saṃ<seg met="-"><gap reason="lost" unit="character" quantity="1"/></seg>
